# Required in production
NODE_ENV=production
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/veloura
JWT_SECRET=replace-with-at-least-32-random-characters

# Provided automatically by most hosts
PORT=5000

# Comma-separated frontend origins when deployed separately.
# Not required for the same-origin single-service deployment.
CLIENT_URL=https://your-domain.com

# Business defaults (0.10 = 10%)
SERVICE_CHARGE_RATE=0.10
DELIVERY_FEE=450
# Required only when running the production seed once
SEED_ADMIN_NAME=Restaurant Owner
SEED_ADMIN_EMAIL=owner@your-domain.com
SEED_ADMIN_PASSWORD=replace-with-a-unique-strong-password
# Optional initial staff account
# SEED_STAFF_NAME=Kitchen Staff
# SEED_STAFF_EMAIL=kitchen@your-domain.com
# SEED_STAFF_PASSWORD=replace-with-another-strong-password